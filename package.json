{
  "name": "makegraph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm db:generate && next build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "dev": "next dev --turbo -p3001",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "upgrade:next": "npx @next/codemod@canary upgrade latest"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.2",
    "@next/third-parties": "^16.2.9",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^1.17.0",
    "modern-screenshot": "^4.7.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "nextjs-toploader": "^3.9.17",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.4",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-color": "^2.19.3",
    "react-datasheet-grid": "^4.11.6",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.10.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.17",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.30.5",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.21.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
